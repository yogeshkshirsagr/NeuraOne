generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id    String  @id
  email String? @unique

  Conversations Conversation[]
  memories      Memory[]
  notes         Note[]
  folders       Folder[]

  ownedWorkspaces Workspace[]       @relation("UserOwnedWorkspaces")
  memberships     WorkspaceMember[]
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  type      String
  createdAt DateTime @default(now())

  ownerId String
  owner   User   @relation("UserOwnedWorkspaces", fields: [ownerId], references: [id])

  Conversations Conversation[]
  folders       Folder[]
  memories      Memory[]
  notes         Note[]
  members       WorkspaceMember[]
  chunks        NoteChunk[]

  @@index([ownerId])
}

model WorkspaceMember {
  id String @id @default(uuid())

  userId      String
  workspaceId String
  role        String

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

model Folder {
  id String @id @default(uuid())

  workspaceId String
  userId      String
  name        String

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  notes     Note[]

  @@index([workspaceId])
  @@index([userId])
}

model Note {
  id String @id @default(uuid())

  workspaceId String
  userId      String
  folderId    String?

  title   String
  content String @db.Text

  // metadata
  type       String      @default("note")
  tags       String[]    @default([])
  summary    String?     @db.Text
  chunks     NoteChunk[]
  isPinned   Boolean     @default(false)
  isArchived Boolean     @default(false)

  // AI memory
  aiSummary      String? @db.Text
  embeddingReady Boolean @default(false)

  embedding Unsupported("vector(1536)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  folder    Folder?   @relation(fields: [folderId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  // RELATIONS
  outgoingRelations NoteRelation[] @relation("FromRelation")
  incomingRelations NoteRelation[] @relation("ToRelation")

  @@index([workspaceId])
  @@index([userId])
  @@index([folderId])
  @@index([type])
  @@index([isPinned])
}

model NoteChunk {
  id String @id @default(cuid())

  noteId      String
  workspaceId String

  note      Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  content String

  chunkIndex Int
  tokenCount Int

  embedding Unsupported("vector(1536)")?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([noteId])
  @@index([workspaceId])
}

model NoteRelation {
  id String @id @default(uuid())

  fromNoteId String
  toNoteId   String

  createdAt DateTime @default(now())

  fromNote Note @relation("FromRelation", fields: [fromNoteId], references: [id], onDelete: Cascade)

  toNote Note @relation("ToRelation", fields: [toNoteId], references: [id], onDelete: Cascade)

  @@index([fromNoteId])
  @@index([toNoteId])
}

//
// AI CONVERSATIONS
//
model Conversation {
  id String @id @default(uuid())

  workspaceId String
  userId      String

  title       String
  lastMessage String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  user User @relation(fields: [userId], references: [id])

  messages ChatMessage[] @relation("ConversationMessages")

  @@index([workspaceId])
  @@index([userId])
}

//
// CHAT MESSAGES
//
model ChatMessage {
  id String @id @default(uuid())

  conversationId String

  role String

  content String @db.Text

  sources Json?

  createdAt DateTime @default(now())

  conversation Conversation @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Memory {
  id String @id @default(uuid())

  content     String
  userId      String
  workspaceId String

  createdAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
}
